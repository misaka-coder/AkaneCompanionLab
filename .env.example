# =============================================================================
# AkaneCompanionLab — .env 配置模板
# =============================================================================
# 使用方法：
#   普通本地用户：在桌面控制中心或 Web 设置中配置“模型服务”，无需编辑本文件。
#   服务器/高级用户：
#   1. 复制此文件为 .env ：  cp .env.example .env
#   2. 按需分别配置 CHAT / AUX / TEXT / VISION
#   3. 其余字段有默认值，可按需覆盖
#
# 标记说明：
#   [必填] = 不填会导致核心功能不可用
#   [建议] = 生产部署建议设置
#   无标记  = 有可用默认值，一般无需修改
# =============================================================================


# =============================================================================
# 1. 运行模式 & 网络
# =============================================================================

# 运行模式：CLOUD=云端服务 LOCAL=本地模式
RUN_MODE=CLOUD

# 监听地址 & 端口
HOST=0.0.0.0
PORT=9999


# =============================================================================
# 2. LLM 密钥 & 接入（核心）
# =============================================================================
# AkaneCompanionLab 支持多协议 LLM 接入：OpenAI 兼容 / Anthropic / Ollama。
# 协议设为 "auto" 时会根据 base_url 自动探测。
#
# 键位角色：
#   TEXT  = 辅助任务（路由判断、记忆总结、时间解析等）
#   CHAT  = 聊天对话（缺失时回退到 TEXT）
#   AUX   = 额外辅助任务（缺失时回退到 TEXT）
#   VISION = 视觉/图像理解（缺失时回退到 CHAT → TEXT）
#
# 控制中心保存的本机模型配置优先于下面的 LLM 字段。
# 纯 .env 部署的最小配置：填写一个 TEXT_API_KEY 及对应地址/模型。

# --- TEXT（辅助任务）[必填，至少要有一个 key] ---
TEXT_API_KEY=
TEXT_BASE_URL=
TEXT_MODEL_NAME=deepseek-chat
TEXT_API_PROTOCOL=auto

# --- CHAT（聊天对话）---
# 不填 key/model 时回退到 TEXT 对应的值。
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL_NAME=
CHAT_API_PROTOCOL=auto

# --- AUX（额外辅助）---
# 不填 key/model 时回退到 TEXT 对应的值。
AUX_API_KEY=
AUX_BASE_URL=
AUX_MODEL_NAME=
AUX_API_PROTOCOL=auto

# --- VISION（视觉/图像理解）---
VISION_ENABLED=true
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL_NAME=
VISION_API_PROTOCOL=auto
VISION_REQUEST_TIMEOUT=60
VISION_PROMPT_VERSION=v1
# 是否自动对场景/礼物/装扮触发视觉观察
VISION_AUTO_SCENE_OBSERVE=true
VISION_AUTO_GIFT_OBSERVE=true
VISION_AUTO_OUTFIT_OBSERVE=true
# 单张图片最大字节数（默认 8 MB）
VISION_MAX_IMAGE_BYTES=8388608


# =============================================================================
# 3. 人设 & 提示词
# =============================================================================

# 自定义人设配置文件路径（TOML），留空使用内置 default。
PERSONA_CONFIG_PATH=

# 使用人设文件中的哪个 variant（对应 TOML 中 [variants.xxx]）
PERSONA_VARIANT=default


# =============================================================================
# 4. 向量记忆 & Embedding
# =============================================================================

# Embedding 提供者：auto | huggingface | hashed
# auto = 尝试本地 HuggingFace sentence-transformers，失败时回退到 hashed
# hashed = 纯本地哈希，无额外依赖，适合最小化部署
EMBEDDING_PROVIDER=auto

# HuggingFace 模型名或本地模型目录（EMBEDDING_PROVIDER=huggingface/auto 时生效）
# 推荐 BAAI/bge-m3；离线使用时可填本地目录，例如 F:/models/bge-m3
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# 设备：空=自动  cuda  cpu
EMBEDDING_DEVICE=

# 只使用本地缓存/本地模型目录，避免启动时联网下载；首次联网下载模型时可临时设为 false
EMBEDDING_LOCAL_FILES_ONLY=true

# HuggingFace Hub 端点：留空=官方源；国内网络下载慢时可设为 https://hf-mirror.com
HF_ENDPOINT=

# HuggingFace/sentence-transformers 缓存目录（留空=默认缓存）
EMBEDDING_CACHE_FOLDER=

# Embedding 模型缓存大小
EMBEDDING_CACHE_SIZE=2048

# 重建索引时的批量大小
EMBEDDING_REINDEX_BATCH_SIZE=64

# 启用语义记忆（长期事实/话题抽取）
ENABLE_SEMANTIC_MEMORY=true

# 启用语义强化（跨会话话题追踪）
ENABLE_SEMANTIC_REINFORCEMENT=true


# =============================================================================
# 5. 记忆 & 检索调优
# =============================================================================

# 预检索默认开关
PRE_RETRIEVAL_DEFAULT_ENABLED=true

# "走神"概率——偶尔插入不相关检索，让回复更自然（0.0 ~ 1.0）
DRIFT_PROBABILITY=0.20

# 触发摘要的累积消息数
SUMMARY_TRIGGER_COUNT=30

# 摘要批处理大小
SUMMARY_BATCH_SIZE=20

# 最近可见摘要数量
RECENT_SUMMARY_LIMIT=5

# 情节记忆压缩触发阈值（条数）
EPISODIC_COMPACT_TRIGGER_COUNT=10

# 情节记忆压缩批处理大小
EPISODIC_COMPACT_BATCH_SIZE=5

# 可见情节记忆最大条数
EPISODIC_VISIBLE_MAX=10

# 可见语义记忆最大条数（过少=缺上下文，过多=prompt 太长）
SEMANTIC_VISIBLE_LIMIT=3

# 语义强化回溯窗口（跨会话）
SEMANTIC_REINFORCEMENT_LOOKBACK=8

# 语义强化最小重叠次数（低于此次数的主题不被强化）
SEMANTIC_REINFORCEMENT_MIN_OVERLAP=2


# =============================================================================
# 6. Prompt 缓存（减少首 token 延迟）
# =============================================================================

# 启用 prompt cache hints（需模型支持，DeepSeek 支持）
PROMPT_CACHE_HINTS_ENABLED=true

# 强制开启 cache hints（即使模型未在已知支持列表中）
PROMPT_CACHE_HINTS_FORCE=false

# 缓存命名空间（用于区分不同实例，避免 key 冲突）
PROMPT_CACHE_NAMESPACE=akane

# 缓存保留策略：空=默认  ephemeral=短期  persistent=长期
PROMPT_CACHE_RETENTION=


# =============================================================================
# 7. 语音 (TTS)
# =============================================================================

# Edge TTS 语音角色
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 语速（相对百分比，如 "+6%" / "-10%"）
TTS_RATE=+6%

# 音量
TTS_VOLUME=+0%

# 音调
TTS_PITCH=+4Hz

# 流式 TTS（边生成边播放）
STREAMING_TTS_ENABLED=true

# GPT-SoVITS 外部 API 默认参数（保持保守；角色声线档案可覆盖部分字段）
GPT_SOVITS_TTS_TIMEOUT_SECONDS=45
GPT_SOVITS_TEXT_LANG=zh
GPT_SOVITS_MEDIA_TYPE=wav
GPT_SOVITS_STREAMING_MODE=false

# 可选推理调参：留空表示不传给 GPT-SoVITS，由外部 API 使用自己的默认值
# GPT_SOVITS_PARALLEL_INFER=true
# GPT_SOVITS_SPLIT_BUCKET=true
# GPT_SOVITS_BATCH_SIZE=1
# GPT_SOVITS_SPEED_FACTOR=1.0
# GPT_SOVITS_FRAGMENT_INTERVAL=0.1
# GPT_SOVITS_TEXT_SPLIT_METHOD=cut5


# =============================================================================
# 8. 公开访问保护 & 限流
# =============================================================================

# 启用公开访问保护（限制并发 & 每日总量）
PUBLIC_GUARD_ENABLED=false

# 最大并发 /think 请求数
MAX_CONCURRENT_THINKS=2

# 每日 /think 请求上限
DAILY_THINK_LIMIT=200

# 繁忙时的提示语
PUBLIC_BUSY_MESSAGE=当前体验人数较多，请稍后再试。

# 每日限额用尽时的提示语
PUBLIC_DAILY_LIMIT_MESSAGE=今日体验名额已满，明天再来看看吧。


# =============================================================================
# 9. 工具调用 & 后台任务
# =============================================================================

# 同轮对话基础工具调用轮次（防止循环）。普通任务建议 2-3；联网/浏览器任务会按工具家族扩展预算。
MAX_TOOL_ROUNDS=3

# 试验性 provider native tool_calls 通道总开关。
# false = 所有工具继续走 legacy JSON tool_call；下面 allowlist 不生效。
# true  = allowlist 内、且当前 (host, model) 能力档案已验证的工具走 native schema。
# 已通过 gate 的只读工具：web_search、retrieve_memory、read_memory_timeline。
# 想本机试用 native 工具时，把这一项改成 true；生产默认建议先保持 false。
ENABLE_NATIVE_TOOL_DECISION=false

# native tool 允许列表，逗号分隔。
# 这只是“候选清单”，是否真的启用仍取决于 ENABLE_NATIVE_TOOL_DECISION。
NATIVE_TOOL_DECISION_ALLOWLIST=web_search,retrieve_memory,read_memory_timeline

# 额外允许 OpenAI-compatible provider/model 走 native tool_calls。
# 默认空：未知中转仍回退 legacy JSON tool_call。
# 格式：host:model 或 host:*；可选第三段 json 表示允许与 response_format=json_object 共存。
# 示例：NATIVE_TOOL_PROVIDER_ALLOWLIST=opencode.ai:deepseek-v4-pro
NATIVE_TOOL_PROVIDER_ALLOWLIST=

# 联网搜索/网页提取类工具的同轮扩展预算。
MAX_WEB_RESEARCH_TOOL_ROUNDS=8

# 托管浏览器打开、滚动、点击、输入类工具的同轮扩展预算。
MAX_BROWSER_TOOL_ROUNDS=10

# 后台 Workshop Worker 最大循环轮次。建议 2-3。
MAX_TASK_WORKER_ROUNDS=3

# Akane 唯一可访问的文件工作区。留空时默认创建在桌面的 Akane Workspace。
# 建议填写绝对路径，例如 D:\Akane Workspace
AKANE_WORKSPACE_ROOT=

# 单个工作区文件允许直接读取的最大字节数（默认 64 MB）。
AKANE_WORKSPACE_MAX_READ_BYTES=67108864

# 后台任务默认并发 Worker 数
BACKGROUND_DEFAULT_WORKERS=1

# 后台附件处理并发 Worker 数
BACKGROUND_ATTACHMENT_WORKERS=3


# =============================================================================
# 10. 调试开关
# =============================================================================
# 默认全部关闭。开启后 /think 流会在日志中输出详细 JSON。

ROUTER_DEBUG=false
VERIFIER_DEBUG=false
FINAL_DEBUG=false


# =============================================================================
# 11. 远程媒体 (yt-dlp)
# =============================================================================

# Cookie 文件路径（用于下载需登录的平台内容）
REMOTE_MEDIA_YTDLP_COOKIEFILE=

# 从浏览器读取 cookie（如 "chrome", "edge"）
REMOTE_MEDIA_YTDLP_COOKIES_FROM_BROWSER=

# 自定义 User-Agent
REMOTE_MEDIA_YTDLP_USER_AGENT=

# Referer 头（默认指向 bilibili）
REMOTE_MEDIA_YTDLP_REFERER=https://www.bilibili.com/


# =============================================================================
# 12. QQ / NapCat 桥接
# =============================================================================
# 需要先部署 NapCat（OneBot HTTP 协议）才能使用 QQ 相关功能。
# 不需要 QQ 功能的话保持 QQ_BRIDGE_ENABLED=false 即可。

# 总开关
QQ_BRIDGE_ENABLED=false

# OneBot HTTP 服务地址
QQ_ONEBOT_HTTP_URL=http://127.0.0.1:3001

# Bot 自己的 QQ 号；由使用者自行填写，留空时仍可使用事件里的 self_id
QQ_BOT_QQ=

# QQ 文字聊天默认使用的 Creator Kit 角色包 id，留空则使用内置 Akane 人设
QQ_CHARACTER_PACK_ID=

# QQ 回复投递模式：text | voice | both | auto
# auto 下模型只能通过 QQ 专属 reply_medium 表达偏好，后端仍会做长度/TTS/发送失败兜底
QQ_REPLY_MODE=auto

# QQ 语音合成读取哪份本地能力配置；留空则使用 WEB_OWNER_PROFILE_USER_ID/master
# 如需恢复按当前 QQ 会话各自读取能力配置，可填 conversation
QQ_TTS_PROFILE_USER_ID=

# QQ 联网搜索读取哪份本地能力配置；留空则使用 WEB_OWNER_PROFILE_USER_ID/master
# 如需恢复按当前 QQ 会话各自读取 AnySearch/MCP 配置，可填 conversation
QQ_WEB_SEARCH_PROFILE_USER_ID=

# QQ 语音回复最大合成文本长度，超过后降级为文字
QQ_VOICE_MAX_TEXT_CHARS=280

# QQ 语音回复最多合成的 speech segment 数
QQ_VOICE_MAX_SEGMENTS=3

# 允许在群聊中使用明文（非 JSON 卡片）模式
QQ_GROUP_PLAINTEXT_ENABLED=false

# 群聊对话跟随的 TTL（秒），超时后发送新卡片
QQ_GROUP_FOLLOW_TTL_SECONDS=180

# 群附件缓冲 TTL（秒），等待多张图片/文件到齐
QQ_GROUP_ATTACHMENT_BUFFER_TTL_SECONDS=180

# 附件去抖间隔（秒），同一消息的多次事件合并
QQ_ATTACHMENT_DEBOUNCE_SECONDS=1.2

# 附件就绪等待时间（秒），等待文件下载完成
QQ_ATTACHMENT_READY_WAIT_SECONDS=8.0

# 多消息段之间的发送间隔（秒）
QQ_REPLY_SEGMENT_DELAY_SECONDS=0.8

# 事件最大有效时间（秒），超过此时间的延迟事件丢弃
QQ_EVENT_MAX_AGE_SECONDS=300

# 允许处理过期事件
QQ_ALLOW_STALE_EVENTS=false

# 仅对明确请求文件投递的消息才发送文件
QQ_REQUIRE_FILE_DELIVERY_INTENT=true

# 附件下载超时（秒）
QQ_ATTACHMENT_DOWNLOAD_TIMEOUT=20.0

# 附件下载最大字节数（默认 20 MB）
QQ_ATTACHMENT_MAX_BYTES=20971520

# QQ 文本消息附件最大读取字节数（默认 256 KB）
QQ_TEXT_ATTACHMENT_MAX_READ_BYTES=262144


# =============================================================================
# 13. Web 身份模式
# =============================================================================
# owner  : 本地主创模式，所有浏览器共享同一主人 profile。
# browser: 每个浏览器分配独立匿名 profile，适合公开试玩。
# invite : 通过 URL 邀请码映射 profile，适合小范围闭测。

WEB_IDENTITY_MODE=owner

# owner 模式下使用的 profile 标识
WEB_OWNER_PROFILE_USER_ID=master


# =============================================================================
# 14. 其他
# =============================================================================

# 主人 QQ 号；由使用者自行填写，留空时私聊使用独立 QQ 身份
MASTER_QQ=
