# Akane VPS deployment example
# Fill this on the server. Do not commit real secrets.

RUN_MODE=CLOUD
HOST=127.0.0.1
PORT=9999

# Persona
PERSONA_VARIANT=default

# Embedding
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=

# If your VPS is small, do not install requirements-ml.txt and keep auto fallback.

# Chat model
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL_NAME=
CHAT_API_PROTOCOL=auto

# Text / aux model
TEXT_API_KEY=
TEXT_BASE_URL=
TEXT_MODEL_NAME=deepseek-chat
TEXT_API_PROTOCOL=auto

AUX_API_KEY=
AUX_BASE_URL=
AUX_MODEL_NAME=deepseek-chat
AUX_API_PROTOCOL=auto

# Vision model
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL_NAME=
VISION_API_PROTOCOL=auto

# TTS
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+6%
TTS_VOLUME=+0%
TTS_PITCH=+4Hz
STREAMING_TTS_ENABLED=false

# Public web guard
PUBLIC_GUARD_ENABLED=false
MAX_CONCURRENT_THINKS=2
DAILY_THINK_LIMIT=200
PUBLIC_BUSY_MESSAGE=当前体验人数较多，请稍后再试。
PUBLIC_DAILY_LIMIT_MESSAGE=今日体验名额已满，明天再来看看 Akane 吧。
